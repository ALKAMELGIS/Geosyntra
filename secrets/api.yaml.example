# Copy to secrets/api.yaml and encrypt with: sops secrets/api.yaml
# Template only — DO NOT commit unencrypted secrets with real values.

express_env: |
  APP_ORIGIN=https://www.geosyntra.org
  APP_BASE_PATH=/
  CORS_ORIGINS=https://www.geosyntra.org
  GEOSYNTRA_API_PORT=3001
  GEOSYNTRA_BIND_HOST=127.0.0.1
  DATABASE_URL=postgres://geosyntra:CHANGE_ME@127.0.0.1:5432/geosyntra_express
  JWT_SECRET=CHANGE_ME
  MAPBOX_TOKEN=
  GOOGLE_OAUTH_CLIENT_ID=
  GOOGLE_OAUTH_CLIENT_SECRET=
  GOOGLE_OAUTH_REDIRECT_URI=https://www.geosyntra.org/oauth-return.html

axum_staging_env: |
  APP_ORIGIN=https://app.geosyntra.org
  CORS_ORIGINS=https://app.geosyntra.org
  GEOSYNTRA_API_PORT=3003
  GEOSYNTRA_BIND_HOST=127.0.0.1
  GEOSYNTRA_WEB_DIST=/var/lib/geosyntra-api-staging/web/public
  DATABASE_URL=postgres://geosyntra:CHANGE_ME@127.0.0.1:5432/geosyntra_axum
  JWT_SECRET=CHANGE_ME
  REDIS_URL=redis://127.0.0.1:6379/0
  STRIPE_SECRET_KEY=
  STRIPE_WEBHOOK_SECRET=
  STRIPE_PRICE_PRO_MONTHLY=
