# Activate with: direnv allow
#
# Targets NixOS / nixpkgs 26.05 ("Yarara") via flake.nix.
# Requires: nix (flakes enabled), direnv
#   mkdir -p ~/.config/nix && echo 'experimental-features = nix-command flakes' >> ~/.config/nix/nix.conf
#
# Nix only sees git-tracked files in a repo — stage flake.nix + .envrc before first allow:
#   git add flake.nix flake.lock .envrc scripts/dev-postgres.sh

use flake

watch_file flake.nix
watch_file flake.lock
watch_file scripts/dev-postgres.sh

# Optional local overrides (gitignored)
dotenv_if_exists .envrc.local
