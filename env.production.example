# GeoSyntra — production environment (copy sections to the correct host)
# Never commit real secrets. This file is safe to commit.

# =============================================================================
# 1) GitHub Pages SPA (frontend static UI at www.geosyntra.org)
#    Set in: GitHub → Settings → Secrets and variables → Actions
#    Built by: .github/workflows/deploy-pages.yml
# =============================================================================
# VITE_API_BASE_URL=https://api.geosyntra.org
# VITE_BASE_PATH=/
# VITE_PRODUCTION_PUBLIC_URL=https://www.geosyntra.org/
# Do NOT set VITE_MAPBOX_TOKEN in CI — Mapbox pk.* is loaded at runtime from the API.

# =============================================================================
# 2) Hostinger Node.js API (api.geosyntra.org)
#    Set in: hPanel → Websites → geosyntra.org → Node.js → Environment Variables
#    OR: hostinger.secrets.env → node scripts/apply-hostinger-api-env.mjs
#    Persists across git redeploys when set in hPanel (recommended).
# =============================================================================
GEOSYNTRA_ENV=production
NODE_ENV=production
APP_ORIGIN=https://www.geosyntra.org
APP_BASE_PATH=/
PORT=3001

# Required for Mapbox basemaps (public pk.* from account.mapbox.com)
MAPBOX_TOKEN=pk.your_public_mapbox_token_here
# Aliases also supported: MAPBOX= / MAPBOX_ACCESS_TOKEN=

# API persistence (volume on Hostinger — outside git clone)
# GEOSYNTRA_DATA_DIR=/home/u245840661/domains/geosyntra.org/geosyntra-data
# GEOSYNTRA_USER_DB_PATH=/home/u245840661/domains/geosyntra.org/geosyntra-data/geosyntra_platform.db
# GEOSYNTRA_API_VAULT_MASTER_KEY=64-char-hex-or-passphrase

# CORS — include production SPA origin (default list includes www.geosyntra.org)
# CORS_ORIGINS=https://www.geosyntra.org,https://geosyntra.org

# OAuth, SMTP, billing — see hostinger.secrets.env.example and .env.example

# =============================================================================
# 3) Local production-like test (optional)
# =============================================================================
# frontend/.env.production.local
# VITE_API_BASE_URL=https://api.geosyntra.org
# VITE_MAPBOX_TOKEN=   # leave empty — use API /api/config/mapbox

# backend/.env (local only — gitignored)
# MAPBOX_TOKEN=pk.your_public_mapbox_token_here

# =============================================================================
# Mapbox production checklist
# =============================================================================
# 1. Create public token at https://account.mapbox.com/access-tokens/
# 2. URL restrictions: https://www.geosyntra.org/* , https://geosyntra.org/*
# 3. Set MAPBOX_TOKEN on Hostinger Node app → Restart PM2 / Node app
# 4. Verify: curl https://api.geosyntra.org/api/config/mapbox
#    → {"configured":true,"publicToken":"pk....","proxyMode":true}
# 5. Redeploy GitHub Pages (push to main) — SPA fetches token at runtime (no rebuild needed for token rotation)
