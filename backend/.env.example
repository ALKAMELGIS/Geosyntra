# GeoSyntra backend — copy to .env (npm run setup creates this automatically)
# Local development only. Production (Hostinger): set vars in hPanel → Node.js → Environment Variables.
# Never commit real API keys. Do not use VITE_* names here — those belong in frontend build only.

GEOSYNTRA_ENV=development
NODE_ENV=development
PORT=3001

JWT_SECRET=change-me-long-random-dev-only
SESSION_SECRET=change-me-long-random-dev-only

# Dev Owner sign-in (auto-created on API startup in development)
RBAC_BOOTSTRAP_EMAIL=admin@geosyntra.com
RBAC_BOOTSTRAP_PASSWORD=GeoSyntra-Admin-2026!
RBAC_BOOTSTRAP_NAME=GeoSyntra Admin
# Or set your own (min 12 chars): GEOSYNTRA_OWNER_PASSWORD=

APP_ORIGIN=http://localhost:5173
APP_BASE_PATH=/
OAUTH_CALLBACK_ORIGIN=http://localhost:3001
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/Geosyntra/oauth-return.html

# SQLite + vault (relative to backend/server/data — portable across machines)
# AGRI_DATA_DIR=data
# AGRI_USER_DB_PATH=geosyntra_platform.db

# Passport + popup exchange (aliases: GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Mapbox public pk.* token — required on Hostinger for Mapbox basemaps in production.
# Set in hPanel → Node.js → Environment Variables (survives redeploy).
# Aliases: MAPBOX, MAPBOX_ACCESS_TOKEN
MAPBOX_TOKEN=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTESERVICE_API_KEY=
SENTINEL_HUB_ACCESS_TOKEN=
SENTINEL_HUB_WMS_INSTANCE_ID=

# Google Maps Platform — Photorealistic 3D basemap (Satellite Intelligence → Basemap → 3D).
# Enable "Map Tiles API" in Google Cloud Console. Proxied at /api/google-3d-tiles/* (key never in browser).
GOOGLE_MAPS_SERVER_API_KEY=
# Alias:
# GOOGLE_MAPS_API_KEY=
