# --- Platform environment (code vs user data) ---
# development | staging | production — backend GEOSYNTRA_ENV should match.
# GEOSYNTRA_ENV=development
# AGRI_DATA_DIR=/data
# Staging/prod: mount a volume at AGRI_DATA_DIR OUTSIDE the git clone.
# VITE_GEOSYNTRA_ENV=staging

VITE_API_BASE_URL=http://localhost:3001
VITE_ENABLE_PWA=false

# --- OAuth (Google / LinkedIn / GitHub / Apple placeholder) ---
# Production Passport callbacks (backend-only flow; secrets never in the SPA):
# GOOGLE_CALLBACK_URL=https://geosyntra.org/api/auth/google/callback
# LINKEDIN_CALLBACK_URL=https://geosyntra.org/api/auth/linkedin/callback
# GITHUB_CALLBACK_URL=https://geosyntra.org/api/auth/github/callback
# Or unified: OAUTH_CALLBACK_ORIGIN=https://geosyntra.org
# SESSION_SECRET=long-random-string
# JWT_SECRET=long-random-string
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# GITHUB_CLIENT_ID=          # login (Passport); admin integration may reuse or use AUTH_GITHUB_*
# GITHUB_CLIENT_SECRET=
# If none of the Google/Apple variables below are set, the login page hides SSO buttons (no runtime error).
# To enable Google: set VITE_AUTH_GOOGLE_CLIENT_ID (and matching GOOGLE_OAUTH_* on the API), or VITE_AUTH_GOOGLE_URL.
# To enable Apple: set VITE_AUTH_APPLE_CLIENT_ID or VITE_AUTH_APPLE_URL.
# Optional: full authorize URL (Auth0, Cognito, custom IdP). Overrides client-id build below.
# VITE_AUTH_GOOGLE_URL=
# VITE_AUTH_APPLE_URL=
# Google: OAuth 2.0 Web client ID. Redirect uses `public/oauth-return.html` → `/#/login?code&state`.
# VITE_AUTH_GOOGLE_CLIENT_ID=
# Optional override when redirect must differ (must match Google Console + server GOOGLE_OAUTH_REDIRECT_URI).
# VITE_AUTH_GOOGLE_REDIRECT_URI=http://localhost:5173/Geosyntra/oauth-return.html
# Apple: Services ID — redirect uses oauth-return.html (same as Google).
# VITE_AUTH_APPLE_CLIENT_ID=
# VITE_AUTH_APPLE_REDIRECT_URI=
# Server: Apple code exchange (required for redirect flow, not only identity_token).
# APPLE_OAUTH_CLIENT_ID=
# APPLE_OAUTH_TEAM_ID=
# APPLE_OAUTH_KEY_ID=
# APPLE_OAUTH_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# APPLE_OAUTH_REDIRECT_URI=https://www.geosyntra.org/oauth-return.html
# GitHub login (separate from admin GitHub integration redirect).
# VITE_AUTH_GITHUB_CLIENT_ID=
# VITE_AUTH_GITHUB_REDIRECT_URI=http://localhost:5173/Geosyntra/oauth-return.html
# AUTH_GITHUB_CLIENT_ID=          # or reuse GITHUB_CLIENT_ID
# AUTH_GITHUB_CLIENT_SECRET=      # or reuse GITHUB_CLIENT_SECRET
# AUTH_GITHUB_REDIRECT_URI=http://localhost:5173/Geosyntra/oauth-return.html
# Server (backend/server): exchange Google code — set alongside the same redirect URI in Google Cloud.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://www.geosyntra.org/oauth-return.html

# Optional: browser tab / header default when System Settings → Header → "Use project name" is on (falls back to frontend/config/app.ts appName).
# VITE_APP_NAME=Geosyntra Platform

# Mapbox public access token (account.mapbox.com).
# Production (GitHub Pages + api.geosyntra.org): leave empty in CI — SPA loads pk.* at runtime via GET /api/config/mapbox.
# Local dev: set VITE_MAPBOX_TOKEN here OR set MAPBOX_TOKEN on the Node API (localhost:3001).
VITE_MAPBOX_TOKEN=
# VITE_MAPBOX_ACCESS_TOKEN=

# Production API host (GitHub Actions secret + local override)
# VITE_API_BASE_URL=https://api.geosyntra.org

# Google Gemini API key for Satellite Intelligence → Table Geo AI (Geo Explorer). Prefer System Settings → API Tokens → Gemini API when the Node API is running (persists to backend/server/agri_api_secrets.json). This env overrides the vault field when set at build time. Never commit a real key.
VITE_GEMINI_API_KEY=

# Geo Explor AI Agent — Google Maps Platform grounding (Grounding Lite MCP-style tools on the Node API).
# Server key: Places API (New), Routes API, Geocoding API, Elevation API. Never expose in the SPA build.
# GOOGLE_MAPS_SERVER_API_KEY=
# Optional alias used by Google's sample app naming:
# SERVER_API_KEY=

# OpenRouteService — Geo AI map routing (driving / walking / cycling). Prefer Settings → API Manager → OpenRouteService (ORS_API_KEY).
# Free key: https://openrouteservice.org/dev/#/signup — also set on the Node host as OPENROUTESERVICE_API_KEY or ORS_API_KEY.
# VITE_OPENROUTESERVICE_API_KEY=

# GraphHopper — Route Map on Satellite Intelligence (Settings → API Tokens → GraphHopper).
# Free key: https://www.graphhopper.com/ — also set on the Node host as GRAPHHOPPER_API_KEY.
# VITE_GRAPHHOPPER_API_KEY=
# VITE_ORS_API_KEY=

# Optional ArcGIS Portal / REST token for secured Feature Services (same as System Settings → API Tokens → agri_arcgis_portal_token_v1).
VITE_ARCGIS_PORTAL_TOKEN=

# Optional Sentinel Hub OGC WMS instance UUID for Satellite Intelligence WMS (overrides System Settings → API Tokens → agri_sentinel_hub_wms_instance_id_v1).
VITE_SENTINEL_HUB_WMS_INSTANCE_ID=

# Optional Sentinel Hub access token (OAuth / Process API) for authenticated Hub requests (overrides System Settings → API Tokens → agri_sentinel_hub_access_token_v1).
VITE_SENTINEL_HUB_ACCESS_TOKEN=

# --- API tokens (persistent — SQLite, per user + platform) ---
# Per-user secrets: `user_api_tokens` (migration 004) — encrypted with AGRI_API_VAULT_MASTER_KEY.
# Platform-wide (Owner): `system_tokens` (migration 003). Hydrated after login via GET /api/user/api-tokens/session (JWT).
# Logout clears session only — API keys remain in the database. Owner UI: Settings → API Manager + Admin → API Tokens.
# AGRI_USER_DB_PATH or AGRI_DATA_DIR must point to a persistent volume in production.
# Users: GET /api/system/tokens/status (configured yes/no only). Integrations call GeoSyntra APIs, not vendor URLs with keys.
# AGRI_BLOCK_CLIENT_SECRET_READS=true
# Do NOT set VITE_ALLOW_CLIENT_API_SECRET_HYDRATION=true in production (dev-only legacy vault sync).
# AGRI_ALLOW_CLIENT_SECRET_HYDRATION=false
# VITE_ALLOW_CLIENT_API_SECRET_HYDRATION=false

# Enterprise gateway (default): Gemini/OpenAI via backend — keys never in browser.
# VITE_USE_API_GATEWAY=true
# VITE_PLATFORM_TOKEN_WS_URL=ws://localhost:3002

# Server env fallbacks (no plaintext in frontend). Prefer Owner Token Manager in DB.
# MAPBOX_ACCESS_TOKEN=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_MAPS_SERVER_API_KEY=
# OPENROUTESERVICE_API_KEY=
# GRAPHHOPPER_API_KEY=

# Legacy JSON vault (optional migration source). Mount on a volume; gitignored.
# AGRI_API_SECRETS_FILE=/data/agri_api_secrets.json

# Optional: legacy static header for automation only — not for browser builds.
# AGRI_API_SECRETS_TOKEN=

# Encrypt tokens at rest (required for production DB + legacy vault). 64-char hex or passphrase.
# AGRI_API_VAULT_MASTER_KEY=
# Auto-backup encrypted vault snapshots on each PUT (directory on persistent volume).
# AGRI_API_VAULT_BACKUP_DIR=/data/api-vault-backups

# Account profile extras (avatar, address, …) sync across browsers when the Node server runs (backend/server/agri_user_profiles.json).
# Leave AGRI_USER_PROFILE_TOKEN unset for local dev only; in production set the same value as VITE_AGRI_USER_PROFILE_TOKEN on the client build.
# AGRI_USER_PROFILE_TOKEN=
# VITE_AGRI_USER_PROFILE_TOKEN=
# Optional absolute base for GET/PUT when the SPA is not same-origin as the API (default: /api/v1/account/profile-extra).
# VITE_AGRI_USER_PROFILE_URL=

# --- Recommended production: SQLite user directory (survives deploys when path is on a volume) ---
# When set, the API stores users + audit + login history in SQLite and auto-migrates from JSON if the DB is empty.
# Example (Docker): AGRI_USER_DB_PATH=/data/geosyntra-users.db
# Leave unset to use JSON file only (AGRI_ADMIN_DIRECTORY_FILE).
# AGRI_USER_DB_PATH=

# User Management + audit log persistence (backend/server/agri_admin_directory.json by default).
# Mount AGRI_ADMIN_DIRECTORY_FILE on a persistent volume in Docker so users/roles survive image rebuilds.
# AGRI_ADMIN_DIRECTORY_FILE=
# AGRI_ADMIN_DIRECTORY_TOKEN=
# VITE_AGRI_ADMIN_DIRECTORY_TOKEN=
# Optional override when the admin UI is not same-origin as the API (default: /api/v1/admin/directory).
# VITE_AGRI_ADMIN_DIRECTORY_URL=

# Email verification (backend/server/authEmail.js) — Resend preferred, SMTP fallback (use SMTP on Hostinger)
# RESEND_API_KEY=
# RESEND_FROM=Geosyntra <onboarding@resend.dev>
# Hostinger mailbox SMTP (see EMAIL_AND_OAUTH_SETUP.md — SPF/DKIM in DNS)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@geosyntra.org
SMTP_PASS=
SMTP_FROM=Geosyntra <noreply@geosyntra.org>
SMTP_SECURE=true
# App URL used in verification links + OAuth redirect default
APP_ORIGIN=https://www.geosyntra.org
APP_BASE_PATH=/

# Billing — Stripe (Pro $100/mo) + trial length (days)
BILLING_TRIAL_DAYS=14
BILLING_PRO_AMOUNT_CENTS=10000
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
# SPA build (public)
# VITE_STRIPE_PUBLISHABLE_KEY=

# AOI live spectral analysis (Python FastAPI) — real pixel zonal stats for map AOI dashboard
# Optional override. Default: same-origin /api/analysis-engine (Node proxy → ANALYSIS_ENGINE_URL).
# VITE_ANALYSIS_ENGINE_URL=http://127.0.0.1:8000

# GeoSyntra AI Detection (DLPK / ONNX / PyTorch) — docker compose -f docker-compose.yml -f docker-compose.ai.yml
VITE_AI_DETECTION_API_URL=http://localhost:8095
# ANALYSIS_ENGINE_URL=http://127.0.0.1:8000
# Run: cd analysis_engine && pip install -r requirements.txt && uvicorn app.main:app --reload --port 8000

# RBAC — JWT sessions (required in production)
# JWT_SECRET=change-me-to-a-long-random-string
# One-time Owner bootstrap on API startup (min 12 char password). Remove after first deploy.
# RBAC_BOOTSTRAP_EMAIL=admin@yourcompany.com
# RBAC_BOOTSTRAP_PASSWORD=your-secure-password-here
# RBAC_BOOTSTRAP_NAME=System Owner
# Or run once: node scripts/create-owner.mjs --email admin@yourcompany.com --generate-password
# Promote an existing account to Owner on API startup (safe to re-run; idempotent).
# RBAC_PROMOTE_OWNER_EMAIL=admin@yourcompany.com
# Permanent system owners (comma-separated). Always Owner + full RBAC on OAuth/login.
# RBAC_SYSTEM_OWNER_EMAILS=admin@Geosyntra.com,ahmed.elfatih@aecom.com
# Same list for the SPA build (comma-separated):
# VITE_RBAC_SYSTEM_OWNER_EMAILS=admin@Geosyntra.com
# GitHub Pages static auth — optional override (min 12 chars); default documented in README
# VITE_STATIC_OWNER_EMAIL=admin@Geosyntra.com
# VITE_STATIC_OWNER_BOOTSTRAP_PASSWORD=
