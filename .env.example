VITE_API_BASE_URL=http://localhost:3001
VITE_ENABLE_PWA=false

# Mapbox public access token (account.mapbox.com). Mapbox GL still needs this token for Esri/OSM raster basemaps in this app.
# Prefer persisting under System Settings → API Tokens (mirrors to backend/server/agri_api_secrets.json when the Node API runs) so updates/rebuilds do not wipe the key.
# If nothing is saved in the browser yet, the build injects one of the variables below (both names are supported; VITE_MAPBOX_TOKEN is checked first).
VITE_MAPBOX_TOKEN=
# VITE_MAPBOX_ACCESS_TOKEN=

# Google Gemini API key for Satellite Intelligence → Table Geo AI (Geo Explorer). Overrides Admin → System Settings → API Tokens → Gemini API (browser). Never commit a real key.
VITE_GEMINI_API_KEY=

# Optional ArcGIS Portal / REST token for secured Feature Services (same as System Settings → API Tokens → agri_arcgis_portal_token_v1).
VITE_ARCGIS_PORTAL_TOKEN=

# Optional Sentinel Hub OGC WMS instance UUID for Satellite Intelligence WMS (overrides System Settings → API Tokens → agri_sentinel_hub_wms_instance_id_v1).
VITE_SENTINEL_HUB_WMS_INSTANCE_ID=

# Optional Sentinel Hub access token (OAuth / Process API) for authenticated Hub requests (overrides System Settings → API Tokens → agri_sentinel_hub_access_token_v1).
VITE_SENTINEL_HUB_ACCESS_TOKEN=

# Server-side API tokens file (shared by all browsers). Mount a Docker volume or host path so it survives image rebuilds.
# Absolute example: AGRI_API_SECRETS_FILE=/data/agri_api_secrets.json
# Relative paths are resolved under backend/server (default when unset: backend/server/agri_api_secrets.json).
# AGRI_API_SECRETS_FILE=

# Optional: lock GET/PUT /api/system/api-secrets (server file backend/server/agri_api_secrets.json).
# If set, the SPA must send the same value as header X-Agri-Api-Secrets-Token (see VITE_AGRI_API_SECRETS_TOKEN).
# AGRI_API_SECRETS_TOKEN=

# Optional: same token as AGRI_API_SECRETS_TOKEN so the browser can sync API keys to the server (exposed in built JS — use only behind a trusted network).
# VITE_AGRI_API_SECRETS_TOKEN=

# Account profile extras (avatar, address, …) sync across browsers when the Node server runs (backend/server/agri_user_profiles.json).
# Leave AGRI_USER_PROFILE_TOKEN unset for local dev only; in production set the same value as VITE_AGRI_USER_PROFILE_TOKEN on the client build.
# AGRI_USER_PROFILE_TOKEN=
# VITE_AGRI_USER_PROFILE_TOKEN=
# Optional absolute base for GET/PUT when the SPA is not same-origin as the API (default: /api/v1/account/profile-extra).
# VITE_AGRI_USER_PROFILE_URL=

# SMTP settings for account verification emails (backend/server/index.js)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
