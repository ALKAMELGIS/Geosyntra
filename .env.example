VITE_API_BASE_URL=http://localhost:3001
VITE_ENABLE_PWA=false

# Mapbox public access token (account.mapbox.com). Required for Mapbox basemaps / globe; leave empty to use Esri/OSM fallbacks only.
VITE_MAPBOX_TOKEN=

# SMTP settings for account verification emails (backend/server/index.js)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
