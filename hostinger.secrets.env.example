APP_BASE_PATH=/
VITE_API_BASE_URL=https://api.geosyntra.org

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://www.geosyntra.org/oauth-return.html

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@geosyntra.org
SMTP_PASS=
SMTP_FROM=Geosyntra <noreply@geosyntra.org>

GEOSYNTRA_ENV=production
NODE_ENV=production
AGRI_DATA_DIR=/home/u245840661/domains/geosyntra.org/geosyntra-data

# ── API tokens (copy into Hostinger hPanel → Node.js App → Environment Variables) ──
# Do NOT put these in frontend VITE_* vars or committed .env files.
# hPanel short names (MAPBOX, OPENAI, DEEPSEEK, OPENROUTESERVICE) are supported.
# Mapbox: use public pk.* token with URL restrictions for www.geosyntra.org
AGRI_API_VAULT_MASTER_KEY=
MAPBOX_TOKEN=pk.your_public_mapbox_token_here
# Optional alias when sk is separate: MAPBOX_PUBLIC_TOKEN=pk....
GEMINI_API_KEY=
OPENAI=
# or OPENAI_API_KEY=sk-...
DEEPSEEK=
OPENROUTESERVICE=
SENTINEL_HUB_ACCESS_TOKEN=
SENTINEL_HUB_WMS_INSTANCE_ID=
ANTHROPIC_API_KEY=
GRAPHHOPPER_API_KEY=
OPENWEATHERMAP_API_KEY=
