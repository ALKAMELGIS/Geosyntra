# node scripts/apply-hostinger-api-env.mjs

# Hostinger — geosyntra.org (server1848, IP 46.202.183.152)
HOSTINGER_SERVER_IP=46.202.183.152
HOSTINGER_FTP_HOST=46.202.183.152
HOSTINGER_FTP_USER=u245840661
HOSTINGER_FTP_PATH=public_html
# HOSTINGER_FTP_PASS=

HOSTINGER_SSH_HOST=46.202.183.152
HOSTINGER_SSH_USER=u245840661
HOSTINGER_SSH_PORT=65002
