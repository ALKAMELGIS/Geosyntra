# Copy to hostinger.secrets.env (gitignored) and fill secrets.
# node scripts/apply-hostinger-api-env.mjs

# Hostinger — geosyntra.org (server1848, IP 46.202.183.152)
HOSTINGER_SERVER_IP=46.202.183.152
HOSTINGER_FTP_HOST=46.202.183.152
HOSTINGER_FTP_USER=u245840661
HOSTINGER_FTP_PATH=public_html
# HOSTINGER_FTP_PASS=

HOSTINGER_SSH_HOST=46.202.183.152
HOSTINGER_SSH_USER=root
HOSTINGER_SSH_PORT=22
# KVM VPS root (geosyntra-deploy backup pull / nixos-anywhere)
VPS_HOST=2.24.11.216
VPS_SSH_USER=root
VPS_SSH_PORT=22
GEOSYNTRA_DEPLOY_HOST=2.24.11.216
# Quote passwords with special chars: VPS_ROOT_PASS='...'
# VPS_ROOT_PASS=
HOSTINGER_APP_DIR=/home/u245840661/domains/geosyntra.org/nodejs
HOSTINGER_PM2_NAME=geosyntra-api
# HOSTINGER_SSH_PASS=

APP_ORIGIN=https://www.geosyntra.org
APP_BASE_PATH=/
VITE_API_BASE_URL=https://api.geosyntra.org

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://www.geosyntra.org/oauth-return.html

# LinkedIn login — register the SAME redirect URL in LinkedIn Developer -> Auth.
# Local dev redirect: http://localhost:5173/Geosyntra/oauth-return.html
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_OAUTH_REDIRECT_URI=https://www.geosyntra.org/oauth-return.html

# GitHub login (separate from the admin GitHub integration).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://www.geosyntra.org/oauth-return.html

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@geosyntra.org
SMTP_PASS=
SMTP_FROM=Geosyntra <noreply@geosyntra.org>

GEOSYNTRA_ENV=production
NODE_ENV=production
GEOSYNTRA_DATA_DIR=/home/u245840661/domains/geosyntra.org/geosyntra-data

# ── API tokens (copy into Hostinger hPanel → Node.js App → Environment Variables) ──
# Do NOT put these in frontend VITE_* vars or committed .env files.
# hPanel short names (MAPBOX, OPENAI, DEEPSEEK, OPENROUTESERVICE) are supported.
# Mapbox: use public pk.* token with URL restrictions for www.geosyntra.org
GEOSYNTRA_API_VAULT_MASTER_KEY=
MAPBOX_TOKEN=pk.your_public_mapbox_token_here
# Optional alias when sk is separate: MAPBOX_PUBLIC_TOKEN=pk....
GEMINI_API_KEY=
OPENAI=
# or OPENAI_API_KEY=sk-...
DEEPSEEK=
OPENROUTESERVICE=
SENTINEL_HUB_ACCESS_TOKEN=
SENTINEL_HUB_WMS_INSTANCE_ID=
ANTHROPIC_API_KEY=
GRAPHHOPPER_API_KEY=
OPENWEATHERMAP_API_KEY=

# ── Database migration & sync (scripts/db-sync.js) ──
# Copy hostinger.secrets.env locally; never commit real credentials.

# Local platform DB (SQLite default — matches backend/data)
DB_LOCAL_DIALECT=sqlite
DB_LOCAL_SQLITE_PATH=backend/server/data/geosyntra_platform.db
# DB_LOCAL_PG_URL=postgresql://user:pass@127.0.0.1:5432/geosyntra_local
# DB_LOCAL_PG_SCHEMA=public

# Production platform DB
DB_PROD_DIALECT=sqlite
# Path to production SQLite (download from server or mount volume)
DB_PROD_SQLITE_PATH=
# Optional: pull/push prod SQLite over SSH (requires --confirm-production to push)
# DB_PROD_SQLITE_SSH_HOST=
# DB_PROD_SQLITE_SSH_PORT=65002
# DB_PROD_SQLITE_SSH_USER=
# DB_PROD_SQLITE_SSH_PASS=
# DB_PROD_SQLITE_SSH_REMOTE_PATH=/home/u245840661/domains/geosyntra.org/geosyntra-data/geosyntra_platform.db
# DB_SYNC_REMOTE_SSH=false

# PostgreSQL namespaces on NixOS (see nix/database-namespaces.nix)
GEOSYNTRA_DB_EXPRESS=geosyntra_express
GEOSYNTRA_DB_AXUM=geosyntra_axum
GEOSYNTRA_DB_GIS=geosyntra_gis
# DB_PROD_PG_URL=postgresql://geosyntra:pass@127.0.0.1:5432/geosyntra_express
# DB_AXUM_PG_URL=postgresql://geosyntra:pass@127.0.0.1:5432/geosyntra_axum

# dry-run | migrate | sync | rollback
DB_MIGRATION_MODE=dry-run
# full | incremental | schema-only
DB_SYNC_STRATEGY=incremental
# skip-duplicate | prod-wins | local-wins
DB_SYNC_CONFLICT_POLICY=skip-duplicate
DB_SYNC_BATCH_SIZE=500
DB_SYNC_REQUIRE_PROD_CONFIRM=yes
DB_SYNC_APPLY_BACKEND_MIGRATIONS=true
DB_BACKUP_DIR=data/db-backups
DB_BACKUP_RETENTION_DAYS=14
DB_SYNC_LOG_DIR=data/db-sync-logs
# Comma-separated; schema_migrations managed by backend migrator
DB_SYNC_TABLE_BLOCKLIST=schema_migrations,sqlite_sequence,db_sync_meta
# DB_SYNC_TABLE_ALLOWLIST=
# DB_GIS_MIGRATION_SQL=db_migration.sql
