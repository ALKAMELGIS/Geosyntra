# GeoSyntra frontend — copy to .env (npm run setup creates this automatically)
# All paths are URLs — never use C:\ or /Users/... machine paths.

GEOSYNTRA_ENV=development

# Axum API (cargo run -p geosyntra-api — default port 3003). Vite proxies /api → this URL in dev.
VITE_API_BASE_URL=http://127.0.0.1:3003

# Vite base path: /Geosyntra/ for GitHub Pages; use / only for custom-domain local builds
# VITE_BASE_PATH=/Geosyntra/

# Mapbox public pk.* — local dev only. Production: leave empty; runtime loads from GET /api/config/mapbox.
VITE_MAPBOX_TOKEN=

# URL-restricted pk.* tokens reject localhost. The Vite dev server proxies api.mapbox.com
# through /__mapbox and injects this Referer so basemaps render in dev. Defaults to
# https://www.geosyntra.org; override as a SHELL env var only if your token is locked to a
# different origin, e.g. (PowerShell):  $env:MAPBOX_DEV_REFERER="https://your-origin"; npm run dev

# Production API (optional local test against Hostinger)
# VITE_API_BASE_URL=https://api.geosyntra.org

# OAuth redirect URIs (must match Google / GitHub / LinkedIn app settings exactly)
VITE_AUTH_GOOGLE_REDIRECT_URI=http://localhost:5173/Geosyntra/oauth-return.html
VITE_AUTH_LINKEDIN_REDIRECT_URI=http://localhost:5173/Geosyntra/oauth-return.html
VITE_AUTH_GITHUB_REDIRECT_URI=http://localhost:5173/Geosyntra/oauth-return.html

# Optional — hydrate from System Settings when API is running
# VITE_GEMINI_API_KEY=
# VITE_ARCGIS_PORTAL_TOKEN=
# VITE_SENTINEL_HUB_WMS_INSTANCE_ID=
# VITE_STRIPE_PUBLISHABLE_KEY=

# Google Maps Platform — Photorealistic 3D basemap (Map Tiles API / 3D Tiles).
# Production: set on the Node API host only (never in the SPA build).
# GOOGLE_MAPS_SERVER_API_KEY=
# Local dev shortcut (optional — bypasses backend proxy when set):
# VITE_GOOGLE_MAPS_API_KEY=
